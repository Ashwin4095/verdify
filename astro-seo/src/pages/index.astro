---
import Layout from "../layouts/Layout.astro";
import Landing from "../components/Landing.jsx";

// Pre-render the index page for massive SSG speed (SEO)
export const prerender = true;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Verdify Intelligence Cloud",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "Sustainability intelligence platform for corporate events in Thailand and MICE/ESG markets. Targeting SET50 companies and hotels for ESG data verification.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout 
  title="Verdify | Sustainability Intelligence for Events" 
  description="Turn every event into verifiable sustainability data and ESG-ready reports. Built for corporate events, MICE markets, and SET50 companies."
  schema={organizationSchema}
>
  <Landing client:load />
</Layout>
